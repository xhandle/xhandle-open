# xhandle-open optional environment variables
# This project is designed to run locally without any .env file.
# Only set these when you explicitly want to override defaults.

# Optional: server port (default 5001)
# PORT=5001

# Optional: comma-separated frontend origins allowed to call the backend.
# Set this in hosted deployments, for example:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# Optional: fixed server-side account identifier for hosted single-tenant deployments.
# XHANDLE_ACCOUNT_ID=xhandle-local

# Optional: only enable this when a trusted upstream auth layer is setting x-account-id.
# TRUST_X_ACCOUNT_ID=false

# Optional: frontend override when the API is hosted on a different origin.
# REACT_APP_BACKEND_URL=https://api.example.com

# Optional: fallback AI provider keys on server.
# Preferred flow is entering keys in the app Settings UI.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Optional: fallback model for /api/openai endpoint
# ANALYSIS_MODEL=gpt-4o-mini

# Optional: GitHub diagnostics route support
# GITHUB_TOKEN=

# Optional: Google Drive integration (if you use /api/files)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
